# Ad-hoc / throwaway output (see CLAUDE.md)
.scratch/

# Mojo / pixi build artifacts
build/
.pixi/

# Python caches (oracle / test scripts)
__pycache__/
*.pyc

# Real-weight kernel fixtures are large (full Qwen2 dims) — regenerate with
# `pixi run kernels-capture`. The small synthetic ones (syn_*) stay committed.
tests/fixtures/kernels/real_*

# Loader fixtures reference a machine-specific checkpoint path; regenerate with
# `pixi run loader-capture`.
tests/fixtures/loader/

# Tokenizer tables are large (151k vocab/merges); regenerate with `pixi run
# tok-capture`.
tests/fixtures/tokenizer/
